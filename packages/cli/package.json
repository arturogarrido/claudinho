{
  "name": "@claudinho/cli",
  "version": "0.4.1",
  "description": "Claudinho CLI — the 2026 men's football tournament in your terminal: live scores, fixtures, group tables, prediction-market odds. Not affiliated with FIFA or Anthropic.",
  "type": "module",
  "license": "MIT",
  "author": "Arturo Garrido",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/arturogarrido/claudinho#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arturogarrido/claudinho.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/arturogarrido/claudinho/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "claudinho": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "football",
    "soccer",
    "world-cup",
    "2026",
    "cli",
    "live-scores",
    "terminal",
    "vibinglavidaloca"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@claudinho/core": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
