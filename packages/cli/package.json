{
  "name": "@claudinho/cli",
  "version": "0.9.1",
  "description": "Live 2026 World Cup scores, fixtures, group tables, and read-only prediction-market signals in your terminal, Claude Code, and Cursor CLI statusline. No API keys. Not affiliated with FIFA or Anthropic.",
  "type": "module",
  "license": "MIT",
  "author": "Arturo Garrido",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/arturogarrido/claudinho#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arturogarrido/claudinho.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/arturogarrido/claudinho/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "claudinho": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "world-cup",
    "world-cup-2026",
    "worldcup",
    "football",
    "soccer",
    "futbol",
    "mundial",
    "live-scores",
    "fixtures",
    "standings",
    "cli",
    "terminal",
    "statusline",
    "claude-code",
    "cursor-cli",
    "2026",
    "vibinglavidaloca",
    "cursor",
    "cursor-agent",
    "mcp",
    "agent"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@claudinho/core": "workspace:*",
    "@types/node": "^22.20.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsup": "^8.0.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  }
}
