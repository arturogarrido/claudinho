{
  "name": "@claudinho/mcp",
  "version": "0.0.0",
  "description": "Claudinho MCP server — ask your agent about the 2026 football tournament. Live scores, fixtures, standings. Not affiliated with FIFA or Anthropic.",
  "type": "module",
  "license": "MIT",
  "author": "Arturo Garrido",
  "homepage": "https://github.com/arturogarrido/claudinho#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arturogarrido/claudinho.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/arturogarrido/claudinho/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "claudinho-mcp": "./dist/index.js"
  },
  "files": ["dist"],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "football",
    "soccer",
    "world-cup",
    "2026",
    "live-scores"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@claudinho/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.21.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
