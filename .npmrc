# Skip the deps-status preflight that pnpm runs before scripts. pnpm 11 escalates
# esbuild's "ignored build script" to a hard error during that preflight, which
# otherwise blocks every script (even pure-tsc typecheck). The esbuild native
# binary is provided directly by the @esbuild/<platform> optional dependency, so
# its postinstall is not needed for tsup/vitest to work.
verify-deps-before-run=false
